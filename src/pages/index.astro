---
import BaseLayout from '../layouts/BaseLayout.astro';

const screenshots = [
  { src: '/screenshots/screenshot1.png', alt: 'FaceOverlay overlay window pinned over a macOS desktop' },
  { src: '/screenshots/screenshot2.png', alt: 'FaceOverlay settings for shape, opacity, and camera controls' },
  { src: '/screenshots/screenshot3.png', alt: 'FaceOverlay webcam overlay used during screen sharing on macOS' },
];
---

<BaseLayout
  title="FaceOverlay for macOS"
  description="A floating webcam overlay for macOS presentations, demos, and calls. Keep your camera feed visible above your desktop with clean, adjustable controls."
>
  <section class="hero-shell">
    <div class="hero-grid">
      <div class="hero-copy">
        <div class="eyebrow">Built for macOS presenters</div>
        <h1>Keep your face on screen.</h1>
        <p class="lede">
          FaceOverlay places a clean, floating webcam window above your Mac so
          demos, tutorials, and screen shares feel human without cluttering the
          rest of your workflow.
        </p>

        <div class="cta-row">
          <a
            class="cta-primary"
            href="https://apps.apple.com/app/id6762126517"
            target="_blank"
            rel="noopener"
          >
            Download on the Mac App Store
          </a>
        </div>

        <ul class="hero-notes">
          <li>Resizable overlay window</li>
          <li>Always-on-top and desktop-following controls</li>
          <li>Mirror, shape, opacity, and blur settings</li>
        </ul>
      </div>

      <div class="hero-visual">
        <div class="visual-frame">
          <div class="hero-carousel-wrap">
            <div class="hero-carousel-track" id="carouselTrack">
              {screenshots.map((shot) => (
                <figure class="hero-shot-card">
                  <img src={shot.src} alt={shot.alt} loading="lazy" />
                </figure>
              ))}
            </div>

            <button class="hero-carousel-btn hero-carousel-prev" id="carouselPrev" aria-label="Previous screenshot">
              &lsaquo;
            </button>
            <button class="hero-carousel-btn hero-carousel-next" id="carouselNext" aria-label="Next screenshot">
              &rsaquo;
            </button>
          </div>

          <div class="carousel-dots hero-carousel-dots" id="carouselDots"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="feature-section" id="features">
    <div class="section-heading">
      <p class="eyebrow">Features</p>
      <h2>Designed for demos, calls, and recorded walkthroughs.</h2>
    </div>

    <div class="feature-grid">
      <article class="feature-card">
        <span class="feature-index">01</span>
        <h3>Floating camera window</h3>
        <p>
          Keep your webcam visible above slides, code, or design tools without
          switching scenes or using complex broadcast software.
        </p>
      </article>

      <article class="feature-card">
        <span class="feature-index">02</span>
        <h3>Precise overlay controls</h3>
        <p>
          Adjust opacity, roundness, shadow, visibility, and size so the camera
          feels intentional instead of pasted on top.
        </p>
      </article>

      <article class="feature-card">
        <span class="feature-index">03</span>
        <h3>Presentation-friendly behavior</h3>
        <p>
          Choose whether the overlay stays above other apps and whether it
          follows you across desktop switching on macOS.
        </p>
      </article>

      <article class="feature-card">
        <span class="feature-index">04</span>
        <h3>Clean camera output</h3>
        <p>
          Select your camera, mirror the image, and enable background blur for a
          lighter-weight alternative to full streaming setups.
        </p>
      </article>
    </div>
  </section>

  <script>
    const track = document.getElementById('carouselTrack');
    const prev = document.getElementById('carouselPrev');
    const next = document.getElementById('carouselNext');
    const dots = document.getElementById('carouselDots');

    if (track && prev && next && dots) {
      const slides = Array.from(track.querySelectorAll('.hero-shot-card'));
      let current = 0;

      const goTo = (index) => {
        current = Math.max(0, Math.min(index, slides.length - 1));
        const slide = slides[current];
        track.scrollTo({
          left: slide.offsetLeft - track.offsetLeft - (track.clientWidth - slide.clientWidth) / 2,
          behavior: 'smooth',
        });
        updateDots();
      };

      const updateDots = () => {
        dots.querySelectorAll('button').forEach((dot, index) => {
          dot.classList.toggle('active', index === current);
        });
      };

      slides.forEach((_, index) => {
        const dot = document.createElement('button');
        dot.setAttribute('aria-label', `Go to screenshot ${index + 1}`);
        dot.addEventListener('click', () => goTo(index));
        if (index === 0) {
          dot.classList.add('active');
        }
        dots.appendChild(dot);
      });

      prev.addEventListener('click', () => goTo(current - 1));
      next.addEventListener('click', () => goTo(current + 1));

      let scrollTimeout;
      track.addEventListener('scroll', () => {
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(() => {
          const center = track.scrollLeft + track.clientWidth / 2;
          let closestIndex = 0;
          let minDistance = Infinity;

          slides.forEach((slide, index) => {
            const midpoint = slide.offsetLeft - track.offsetLeft + slide.clientWidth / 2;
            const distance = Math.abs(center - midpoint);
            if (distance < minDistance) {
              minDistance = distance;
              closestIndex = index;
            }
          });

          current = closestIndex;
          updateDots();
        }, 50);
      });
    }
  </script>
</BaseLayout>

<style>
  .hero-shell,
  .feature-section {
    max-width: 1160px;
    margin: 0 auto;
    padding-left: 24px;
    padding-right: 24px;
  }

  .hero-shell {
    padding-top: 56px;
    padding-bottom: 44px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.06fr) minmax(320px, 0.94fr);
    gap: 34px;
    align-items: center;
  }

  .hero-copy {
    padding: 8px 0;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid rgba(167, 230, 255, 0.18);
    background: rgba(167, 230, 255, 0.08);
    color: var(--ice);
    font-size: 0.83rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 20px;
  }

  h1 {
    font-size: clamp(2.6rem, 6.2vw, 5rem);
    line-height: 0.92;
    max-width: 10ch;
  }

  .lede {
    margin-top: 22px;
    max-width: 42rem;
    color: var(--muted);
    font-size: 1.14rem;
  }

  .cta-row {
    margin-top: 30px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 0 22px;
    border-radius: 999px;
    font-weight: 700;
    transition: transform 180ms ease, box-shadow 180ms ease;
    background: linear-gradient(135deg, #fefefe 0%, #b7ecff 100%);
    color: #041018;
    box-shadow: 0 18px 40px rgba(84, 195, 255, 0.22);
  }

  .cta-primary:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }

  .hero-notes {
    margin: 28px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 10px;
  }

  .hero-notes li {
    color: var(--muted);
    padding-left: 22px;
    position: relative;
  }

  .hero-notes li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--cyan), var(--amber));
  }

  .hero-visual {
    position: relative;
  }

  .visual-frame {
    position: relative;
    min-height: 520px;
    padding: 30px 30px 20px;
    border-radius: 40px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background:
      radial-gradient(circle at 30% 20%, rgba(84, 195, 255, 0.28), transparent 24%),
      radial-gradient(circle at 72% 70%, rgba(246, 184, 74, 0.24), transparent 20%),
      linear-gradient(180deg, rgba(14, 19, 28, 0.96), rgba(8, 10, 14, 0.98));
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .visual-frame::after {
    content: '';
    position: absolute;
    inset: 18px;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hero-carousel-wrap,
  .hero-carousel-dots {
    position: relative;
    z-index: 1;
  }

  .hero-carousel-wrap {
    height: 100%;
    display: flex;
    align-items: center;
  }

  .hero-carousel-track {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    width: 100%;
    padding: 8px 4px;
  }

  .hero-carousel-track::-webkit-scrollbar {
    display: none;
  }

  .hero-shot-card {
    flex: 0 0 100%;
    margin: 0;
    scroll-snap-align: center;
    border-radius: 26px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background: var(--panel-strong);
    box-shadow: 0 22px 56px rgba(0, 0, 0, 0.34);
  }

  .hero-shot-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .hero-carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 42px;
    height: 42px;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    color: var(--text);
    font-size: 1.5rem;
    background: rgba(10, 14, 22, 0.84);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(14px);
  }

  .hero-carousel-prev {
    left: 12px;
  }

  .hero-carousel-next {
    right: 12px;
  }

  .feature-section {
    padding-top: 28px;
    padding-bottom: 76px;
  }

  .section-heading {
    max-width: 780px;
    margin-bottom: 26px;
  }

  .section-heading h2 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .feature-card {
    padding: 24px;
    border-radius: 28px;
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }

  .feature-index {
    display: inline-block;
    margin-bottom: 18px;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    color: var(--amber);
  }

  .feature-card h3 {
    font-size: 1.45rem;
    margin-bottom: 8px;
  }

  .feature-card p {
    color: var(--muted);
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 18px;
  }

  .carousel-dots :global(button) {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.16);
    padding: 0;
    cursor: pointer;
  }

  .carousel-dots :global(button.active) {
    background: linear-gradient(135deg, var(--cyan), var(--amber));
  }

  @media (max-width: 980px) {
    .hero-grid,
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .visual-frame {
      min-height: 420px;
    }
  }

  @media (max-width: 720px) {
    .hero-shell {
      padding-top: 32px;
    }

    .hero-carousel-btn {
      display: none;
    }
  }
</style>
