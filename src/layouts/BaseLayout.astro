---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'FaceOverlay puts your webcam above your desktop for demos, calls, and screen sharing with a clean floating macOS overlay.',
  ogImage = '/screenshots/screenshot1.png',
} = Astro.props;

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : Astro.url;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="author" content="Kuip Limited" />
    <meta name="application-name" content="FaceOverlay" />
    <meta name="apple-mobile-web-app-title" content="FaceOverlay" />
    <meta name="theme-color" content="#05070b" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="FaceOverlay" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? Astro.url)} />
    <meta property="og:image:alt" content="FaceOverlay for macOS" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site ?? Astro.url)} />
    <meta name="twitter:image:alt" content="FaceOverlay for macOS" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'SoftwareApplication',
        name: 'FaceOverlay',
        operatingSystem: 'macOS',
        applicationCategory: 'MultimediaApplication',
        description,
        downloadUrl: 'https://apps.apple.com/app/id6762126517',
        url: Astro.site ?? 'https://faceoverlay.kuip.co.uk',
        image: new URL('/screenshots/screenshot1.png', Astro.site ?? Astro.url).toString(),
        screenshot: [
          new URL('/screenshots/screenshot1.png', Astro.site ?? Astro.url).toString(),
          new URL('/screenshots/screenshot2.png', Astro.site ?? Astro.url).toString(),
          new URL('/screenshots/screenshot3.png', Astro.site ?? Astro.url).toString(),
        ],
        isAccessibleForFree: true,
        offers: {
          '@type': 'Offer',
          price: '0',
          priceCurrency: 'USD',
          availability: 'https://schema.org/InStock',
        },
        featureList: [
          'Floating webcam overlay on macOS',
          'Resizable always-on-top camera window',
          'Desktop-following overlay behavior',
          'Rounded mask control and opacity settings',
          'Camera selection and image mirroring',
          'Background blur for cleaner presentations',
        ],
        author: {
          '@type': 'Organization',
          name: 'Kuip Limited',
          url: Astro.site ?? 'https://faceoverlay.kuip.co.uk',
        },
        publisher: {
          '@type': 'Organization',
          name: 'Kuip Limited',
          url: Astro.site ?? 'https://faceoverlay.kuip.co.uk',
        },
      })}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'Kuip Limited',
        url: Astro.site ?? 'https://faceoverlay.kuip.co.uk',
        brand: {
          '@type': 'Brand',
          name: 'FaceOverlay',
        },
      })}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'FaceOverlay',
        url: Astro.site ?? 'https://faceoverlay.kuip.co.uk',
        publisher: {
          '@type': 'Organization',
          name: 'Kuip Limited',
        },
      })}
    />

    <style is:global>
      :root {
        --bg: #05070b;
        --panel: rgba(14, 19, 28, 0.8);
        --panel-strong: rgba(11, 16, 24, 0.94);
        --line: rgba(255, 255, 255, 0.12);
        --text: #edf1f7;
        --muted: #a4adbb;
        --ice: #a7e6ff;
        --cyan: #54c3ff;
        --amber: #f6b84a;
        --shadow: 0 28px 80px rgba(0, 0, 0, 0.45);
        --radius: 24px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top left, rgba(84, 195, 255, 0.18), transparent 26%),
          radial-gradient(circle at 82% 14%, rgba(246, 184, 74, 0.14), transparent 24%),
          linear-gradient(180deg, #08101a 0%, #05070b 36%, #040507 100%);
        color: var(--text);
        font-family: 'Avenir Next', 'Segoe UI', sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.26;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
        background-size: 80px 80px;
        mask-image: radial-gradient(circle at center, black, transparent 78%);
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: 'Iowan Old Style', 'Palatino Linotype', serif;
        letter-spacing: -0.03em;
        margin: 0;
      }

      p {
        margin: 0;
      }

      a {
        color: var(--ice);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      img {
        max-width: 100%;
        display: block;
      }
    </style>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a class="brand" href="/">
          <img src="/icons/brand.svg" alt="FaceOverlay" class="brand-mark" />
          <span>FaceOverlay</span>
        </a>
        <div class="nav-links">
          <a href="#features">Features</a>
          <a href="#screenshots">Screenshots</a>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <p>
          &copy; {new Date().getFullYear()} Kuip Limited. All rights reserved.
          <br />
          <a
            href="#"
            id="contact-email-link"
            data-user="kuip.ltd.open"
            data-domain="gmail.com"
          >
            Contact email
          </a>
        </p>
        <p>
          <a href="/privacy">Privacy Policy</a>
          <span class="divider">•</span>
          <a href="/terms">Terms of Service</a>
          <span class="divider">•</span>
          <a href="https://apps.apple.com/app/id6762126517" target="_blank" rel="noopener">Mac App Store</a>
        </p>
      </div>
    </footer>

    <script>
      const emailLink = document.getElementById('contact-email-link');
      if (emailLink) {
        const user = emailLink.getAttribute('data-user');
        const domain = emailLink.getAttribute('data-domain');

        if (user && domain) {
          const email = `${user}@${domain}`;
          emailLink.setAttribute('href', `mailto:${email}`);
          emailLink.textContent = email;
        }
      }
    </script>

    <style>
      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(18px);
        background: rgba(5, 7, 11, 0.62);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      .nav-inner,
      .footer-inner {
        max-width: 1160px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .nav-inner {
        min-height: 78px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        color: var(--text);
        font-weight: 700;
        font-size: 1rem;
      }

      .brand:hover {
        text-decoration: none;
      }

      .brand-mark {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        box-shadow: 0 10px 26px rgba(84, 195, 255, 0.18);
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
      }

      .nav-links a {
        color: var(--muted);
        font-size: 0.94rem;
      }

      .nav-links a:hover {
        color: var(--text);
        text-decoration: none;
      }

      .footer {
        padding: 28px 0 52px;
      }

      .footer-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        color: var(--muted);
        font-size: 0.92rem;
        border-top: 1px solid var(--line);
        padding-top: 24px;
      }

      .divider {
        margin: 0 10px;
        color: rgba(255, 255, 255, 0.28);
      }

      @media (max-width: 820px) {
        .nav-inner,
        .footer-inner {
          flex-direction: column;
          align-items: flex-start;
        }

        .nav-inner {
          padding-top: 16px;
          padding-bottom: 16px;
        }

        .footer-inner {
          align-items: flex-start;
        }
      }
    </style>
  </body>
</html>
